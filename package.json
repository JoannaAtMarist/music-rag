{
    "name": "music-rag",
    "version": "0.1.0",
    "description": "Local music library scanner and RAG learning project",
    "main": "dist/index.js",
    "type": "module",
    "scripts": {
        "scan": "tsx src/scanner/scanLibrary.ts",
        "chunk": "tsx src/core/createChunks.ts",
        "embed": "tsx src/core/createEmbeddings.ts",
        "search": "tsx src/core/search.ts",
        "visualize:data": "tsx src/core/createVisualizationData.ts",
        "visualize": "serve .",
        "typecheck": "tsc --noEmit",
        "build": "tsc"
    },
    "keywords": [
        "music",
        "rag",
        "embeddings",
        "metadata",
        "typescript"
    ],
    "author": "",
    "license": "MIT",
    "dependencies": {
        "dotenv": "^17.4.2",
        "ml-pca": "^4.1.1",
        "music-metadata": "^11.0.0",
        "openai": "^6.34.0"
    },
    "devDependencies": {
        "@types/node": "^22.19.17",
        "serve": "^14.2.6",
        "tsx": "^4.20.0",
        "typescript": "^5.8.0"
    }
}
